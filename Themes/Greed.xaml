<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Double x:Key="GrainOpacity">0.32</sys:Double>
    <sys:Double x:Key="IconShadowOpacity">1.0</sys:Double>

    <!-- KillerScan - GREED theme. Ported from KillerPDF Themes/Greed.xaml. -->
    <SolidColorBrush x:Key="PrimaryBrush"        Color="#3fbf6f" po:Freeze="True"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#3fbf6f" po:Freeze="True"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#3fbf6f" po:Freeze="True"/>
    <SolidColorBrush x:Key="HeaderLineBrush"     Color="#2a7a4a" po:Freeze="True"/>
    <SolidColorBrush x:Key="OnPrimaryBrush"      Color="#04241a" po:Freeze="True"/>
    <SolidColorBrush x:Key="OutlineBtnBrush"     Color="#e0d49a" po:Freeze="True"/>
    <SolidColorBrush x:Key="InputHoverBrush"     Color="#6e8270" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextFooter"          Color="#3a8a5a" po:Freeze="True"/>

    <SolidColorBrush x:Key="BackgroundBrush"     Color="#002115" po:Freeze="True"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#002e1c" po:Freeze="True"/>
    <SolidColorBrush x:Key="PaneBrush"           Color="#003824" po:Freeze="True"/>
    <SolidColorBrush x:Key="TableHeaderBrush"    Color="#002e1c" po:Freeze="True"/>
    <SolidColorBrush x:Key="CardBorderBrush"     Color="#0f4a30" po:Freeze="True"/>
    <SolidColorBrush x:Key="PaneBorderBrush"     Color="#0f4a30" po:Freeze="True"/>

    <SolidColorBrush x:Key="TextBrush"           Color="#fffde8" po:Freeze="True"/>
    <SolidColorBrush x:Key="MutedTextBrush"      Color="#e0d49a" po:Freeze="True"/>
    <SolidColorBrush x:Key="ChromeTextBrush"     Color="#ece2bc" po:Freeze="True"/>
    <SolidColorBrush x:Key="DimTextBrush"        Color="#c0aa68" po:Freeze="True"/>

    <SolidColorBrush x:Key="RowAltBrush"         Color="#18FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="RowHoverBrush"       Color="#00593a" po:Freeze="True"/>
    <SolidColorBrush x:Key="RowSelectedBrush"    Color="#44ffffff" po:Freeze="True"/>

    <SolidColorBrush x:Key="InputBorderBrush"    Color="#0f4a30" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#003521" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuBorderBrush"     Color="#0f4a30" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuTextBrush"       Color="#e0d49a" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuHoverBrush"      Color="#00593a" po:Freeze="True"/>
    <SolidColorBrush x:Key="OutlinePressedBrush" Color="#44ffffff" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbBrush"    Color="#aae0d49a" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#f2ead0" po:Freeze="True"/>

    <!-- Device-type label colours (bright, for dark panes) -->
    <SolidColorBrush x:Key="TypeRouter"     Color="#F0A030" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeWindows"    Color="#60A0F0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypePrinter"    Color="#D080A0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeSwitch"     Color="#C0C0C0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeHypervisor" Color="#E06060" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeNas"        Color="#7BE06A" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeIot"        Color="#B060D0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeServer"     Color="#E08050" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeLinux"      Color="#D0C050" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeDns"        Color="#50B0D0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeHa"         Color="#38D6CC" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeMobile"     Color="#A0A0F0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeCamera"     Color="#F0C060" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeSmarttv"    Color="#E0A0E0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeMedia"      Color="#70C0E0" po:Freeze="True"/>

    <!-- Keyboard-map category colors (F1 overlay KEYBOARD view, KillerPDF palette) -->
    <SolidColorBrush x:Key="KnCatFile"   Color="#00fff9" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatNote"   Color="#ff2975" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatFormat" Color="#ffd319" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatView"   Color="#f222ff" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatSearch" Color="#00b3ff" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatHelp"   Color="#39ff14" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatEdit"   Color="#ff901f" po:Freeze="True"/>

</ResourceDictionary>

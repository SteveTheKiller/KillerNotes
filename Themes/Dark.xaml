<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Double x:Key="GrainOpacity">0.24</sys:Double>
    <sys:Double x:Key="IconShadowOpacity">0.9</sys:Double>

    <!-- ================================================================
         KillerScan - DARK theme (colours + brushes only). Tiered surface
         hierarchy ported from KillerPDF:
           Background = chrome   (#1c1c1c) - window, titlebar, footer (blend)
           Surface    = bar      (#333333) - scan config bar, table header
           Pane       = content  (#3a3a3a) - devices pane + grid rows (lightest)
         Borders (CardBorder) separate the tiers. ThemeManager swaps this
         dictionary's keys in place at runtime - colours/brushes only here.
         ================================================================ -->

    <!-- Accent -->
    <SolidColorBrush x:Key="PrimaryBrush"        Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="HeaderLineBrush"     Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="OnPrimaryBrush"      Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="OutlineBtnBrush"     Color="#1ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="InputHoverBrush"     Color="#707070" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextFooter"          Color="#6a6a6a" po:Freeze="True"/>

    <!-- Surface tiers -->
    <SolidColorBrush x:Key="BackgroundBrush"     Color="#1c1c1c" po:Freeze="True"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#333333" po:Freeze="True"/>
    <SolidColorBrush x:Key="PaneBrush"           Color="#3a3a3a" po:Freeze="True"/>
    <SolidColorBrush x:Key="TableHeaderBrush"    Color="#333333" po:Freeze="True"/>
    <SolidColorBrush x:Key="CardBorderBrush"     Color="#2e2e2e" po:Freeze="True"/>
    <SolidColorBrush x:Key="PaneBorderBrush"     Color="#3f3f3f" po:Freeze="True"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush"           Color="#e0e0e0" po:Freeze="True"/>
    <SolidColorBrush x:Key="MutedTextBrush"      Color="#a0a0a0" po:Freeze="True"/>
    <SolidColorBrush x:Key="ChromeTextBrush"     Color="#b6b6b6" po:Freeze="True"/>
    <SolidColorBrush x:Key="DimTextBrush"        Color="#6a6a6a" po:Freeze="True"/>

    <!-- Grid rows -->
    <SolidColorBrush x:Key="RowAltBrush"         Color="#18FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="RowHoverBrush"       Color="#404040" po:Freeze="True"/>
    <SolidColorBrush x:Key="RowSelectedBrush"    Color="#0d2a18" po:Freeze="True"/>

    <!-- Inputs / menus / scrollbar -->
    <SolidColorBrush x:Key="InputBorderBrush"    Color="#2e2e2e" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#363636" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuBorderBrush"     Color="#2e2e2e" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuTextBrush"       Color="#a0a0a0" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuHoverBrush"      Color="#404040" po:Freeze="True"/>
    <SolidColorBrush x:Key="OutlinePressedBrush" Color="#0d2a18" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbBrush"    Color="#551ea54c" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#1ea54c" po:Freeze="True"/>

    <!-- Device-type label colours (bright, for dark panes) -->
    <SolidColorBrush x:Key="TypeRouter"     Color="#F0A030" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeWindows"    Color="#60A0F0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypePrinter"    Color="#D080A0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeSwitch"     Color="#C0C0C0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeHypervisor" Color="#E06060" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeNas"        Color="#40C080" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeIot"        Color="#B060D0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeServer"     Color="#E08050" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeLinux"      Color="#D0C050" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeDns"        Color="#50B0D0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeHa"         Color="#50D0A0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeMobile"     Color="#A0A0F0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeCamera"     Color="#F0C060" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeSmarttv"    Color="#E0A0E0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeMedia"      Color="#70C0E0" po:Freeze="True"/>

    <!-- Keyboard-map category colors (F1 overlay KEYBOARD view, KillerPDF palette) -->
    <SolidColorBrush x:Key="KnCatFile"   Color="#00fff9" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatNote"   Color="#ff2975" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatFormat" Color="#ffd319" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatView"   Color="#f222ff" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatSearch" Color="#00b3ff" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatHelp"   Color="#39ff14" po:Freeze="True"/>

</ResourceDictionary>

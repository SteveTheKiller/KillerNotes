<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Double x:Key="GrainOpacity">0.24</sys:Double>
    <sys:Double x:Key="IconShadowOpacity">0.9</sys:Double>

    <!-- KillerScan - BLACK theme. OLED-style near-black with subtle surface tiering so
         elements read by background, not by bright borders (borders kept dark). -->
    <SolidColorBrush x:Key="PrimaryBrush"        Color="#00ff66" po:Freeze="True"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#00ff66" po:Freeze="True"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#00ff66" po:Freeze="True"/>
    <SolidColorBrush x:Key="HeaderLineBrush"     Color="#00ff66" po:Freeze="True"/>
    <SolidColorBrush x:Key="OnPrimaryBrush"      Color="#0a0a0a" po:Freeze="True"/>
    <SolidColorBrush x:Key="OutlineBtnBrush"     Color="#00ff66" po:Freeze="True"/>
    <SolidColorBrush x:Key="InputHoverBrush"     Color="#8c8c8c" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextFooter"          Color="#aaaaaa" po:Freeze="True"/>

    <SolidColorBrush x:Key="BackgroundBrush"     Color="#000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#0d0d0d" po:Freeze="True"/>
    <SolidColorBrush x:Key="PaneBrush"           Color="#161616" po:Freeze="True"/>
    <SolidColorBrush x:Key="TableHeaderBrush"    Color="#0d0d0d" po:Freeze="True"/>
    <SolidColorBrush x:Key="CardBorderBrush"     Color="#2a2a2a" po:Freeze="True"/>
    <SolidColorBrush x:Key="PaneBorderBrush"     Color="#1c1c1c" po:Freeze="True"/>
    <!-- DWM window frame: pane borders are intentionally near-black here, so the
         frame uses the card border tone instead. -->
    <SolidColorBrush x:Key="AppBorderBrush"      Color="#2a2a2a" po:Freeze="True"/>

    <SolidColorBrush x:Key="TextBrush"           Color="#ffffff" po:Freeze="True"/>
    <SolidColorBrush x:Key="MutedTextBrush"      Color="#cccccc" po:Freeze="True"/>
    <SolidColorBrush x:Key="ChromeTextBrush"     Color="#dcdcdc" po:Freeze="True"/>
    <SolidColorBrush x:Key="DimTextBrush"        Color="#888888" po:Freeze="True"/>

    <SolidColorBrush x:Key="RowAltBrush"         Color="#14FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="RowHoverBrush"       Color="#242424" po:Freeze="True"/>
    <SolidColorBrush x:Key="RowSelectedBrush"    Color="#003322" po:Freeze="True"/>

    <SolidColorBrush x:Key="InputBorderBrush"    Color="#2a2a2a" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#121212" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuBorderBrush"     Color="#2a2a2a" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuTextBrush"       Color="#cccccc" po:Freeze="True"/>
    <SolidColorBrush x:Key="MenuHoverBrush"      Color="#242424" po:Freeze="True"/>
    <SolidColorBrush x:Key="OutlinePressedBrush" Color="#003322" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbBrush"    Color="#8800ff66" po:Freeze="True"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#00ff66" po:Freeze="True"/>

    <!-- Device-type label colours (bright, for dark panes) -->
    <SolidColorBrush x:Key="TypeRouter"     Color="#F0A030" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeWindows"    Color="#60A0F0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypePrinter"    Color="#D080A0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeSwitch"     Color="#C0C0C0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeHypervisor" Color="#E06060" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeNas"        Color="#40C080" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeIot"        Color="#B060D0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeServer"     Color="#E08050" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeLinux"      Color="#D0C050" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeDns"        Color="#50B0D0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeHa"         Color="#50D0A0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeMobile"     Color="#A0A0F0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeCamera"     Color="#F0C060" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeSmarttv"    Color="#E0A0E0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TypeMedia"      Color="#70C0E0" po:Freeze="True"/>

    <!-- Keyboard-map category colors (F1 overlay KEYBOARD view, KillerPDF palette) -->
    <SolidColorBrush x:Key="KnCatFile"   Color="#00fff9" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatNote"   Color="#ff2975" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatFormat" Color="#ffd319" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatView"   Color="#f222ff" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatSearch" Color="#00b3ff" po:Freeze="True"/>
    <SolidColorBrush x:Key="KnCatHelp"   Color="#39ff14" po:Freeze="True"/>

</ResourceDictionary>

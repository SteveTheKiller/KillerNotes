<Application x:Class="KillerNotes.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- [0] is swapped in place at runtime by ThemeManager. Black is the
                     KillerNotes default (with the Purple accent, set in ThemeManager). -->
                <ResourceDictionary Source="Themes/Black.xaml"/>
                <ResourceDictionary Source="Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

<!-- KillerUI kit. Themed confirm dialog: same surface, grain, shadow, and wordmark
     language as the main window. Used by About.cs for the self-update prompt; reuse it
     anywhere a MessageBox would break the look (install prompts, destructive confirms). -->
<Window x:Class="KillerNotes.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KillerNotes"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False">

    <!-- Margin is a transparent halo so the drop shadow has room to render (AllowsTransparency window,
         so WPF draws the shadow rather than the OS). Same shadow language as the KillerPDF KillerDialog. -->
    <Border x:Name="RootBorder" Opacity="0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <!-- Film grain over the whole dialog (behind content), so it reads as one continuous
                 surface like the main window chrome. -->
            <Border IsHitTestVisible="False" CornerRadius="6"
                    Opacity="{DynamicResource GrainOpacity}"
                    Background="{DynamicResource GrainTileBrush}"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title bar: transparent so the dialog grain + surface show through and the bar blends
                     into the window instead of reading as a separate strip. Carries the app wordmark
                     (Killer in text color, second word bold in the accent) like the main title bar. -->
                <Border Grid.Row="0" Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0">
                        <!-- Wordmark with the same soft dark shadow copy the main title bar uses. -->
                        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="1,2,0,0"
                                        Opacity="{DynamicResource IconShadowOpacity}">
                                <StackPanel.Effect><BlurEffect Radius="3"/></StackPanel.Effect>
                                <TextBlock FontFamily="{DynamicResource WordmarkFont}" FontSize="15"><Run Text="Killer" Foreground="#D8000000"/><Run Text="Notes" FontSize="19.5" FontWeight="Bold" Foreground="#D8000000"/></TextBlock>
                            </StackPanel>
                            <TextBlock FontFamily="{DynamicResource WordmarkFont}" FontSize="15"><Run Text="Killer" Foreground="{DynamicResource TextBrush}"/><Run Text="Notes" FontSize="19.5" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/></TextBlock>
                        </Grid>
                        <!-- KillerPDF-style X: just the glyph reddens on hover, no filled block -->
                        <Button Content="&#x2715;" Click="Cancel_Click"
                                HorizontalAlignment="Right"
                                Width="28" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#E04444"/>
                                                        <Setter TargetName="cp" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.5"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Body (defaults are placeholders; the configurable ctor overwrites them) -->
                <StackPanel Grid.Row="1" Margin="24,20,24,16">
                    <TextBlock x:Name="HeadingText" Text="Install KillerNotes to your user profile?"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <TextBlock x:Name="DetailText" Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" LineHeight="20" TextWrapping="Wrap">
                        <Run Text="- Start Menu shortcut"/>
                        <LineBreak/>
                        <Run Text="- Appears in Add/Remove Programs"/>
                    </TextBlock>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="24,0,24,20">
                    <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click"
                            Style="{StaticResource SurfaceButton}"
                            Width="80" Margin="0,0,8,0"/>
                    <!-- OutlineButton (family standard, like KillerScan's Scan button):
                         accent outline at rest, fills solid on hover -->
                    <Button x:Name="OkButton" Content="Install" Click="OK_Click"
                            Style="{StaticResource OutlineButton}"
                            Width="80"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

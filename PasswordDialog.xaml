<!-- Themed password prompt: same surface, grain, and shadow language as ConfirmDialog.
     One box to unlock; a second confirm box appears for set/change (showConfirm ctor arg). -->
<Window x:Class="KillerNotes.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KillerNotes"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border x:Name="RootBorder" Opacity="0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Border IsHitTestVisible="False" CornerRadius="6"
                    Opacity="{DynamicResource GrainOpacity}"
                    Background="{DynamicResource GrainTileBrush}"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title bar: transparent, wordmark, drag, close -->
                <Border Grid.Row="0" Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="14,0">
                        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="1,2,0,0"
                                        Opacity="{DynamicResource IconShadowOpacity}">
                                <StackPanel.Effect><BlurEffect Radius="3"/></StackPanel.Effect>
                                <TextBlock FontFamily="{DynamicResource WordmarkFont}" FontSize="15"><Run Text="Killer" Foreground="#D8000000"/><Run Text="Notes" FontSize="19.5" FontWeight="Bold" Foreground="#D8000000"/></TextBlock>
                            </StackPanel>
                            <TextBlock FontFamily="{DynamicResource WordmarkFont}" FontSize="15"><Run Text="Killer" Foreground="{DynamicResource TextBrush}"/><Run Text="Notes" FontSize="19.5" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/></TextBlock>
                        </Grid>
                        <!-- KillerPDF-style X: just the glyph reddens on hover, no filled block -->
                        <Button Content="&#x2715;" Click="Cancel_Click"
                                HorizontalAlignment="Right"
                                Width="28" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#E04444"/>
                                                        <Setter TargetName="cp" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.5"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- Body -->
                <StackPanel Grid.Row="1" Margin="24,20,24,16">
                    <TextBlock x:Name="HeadingText" Text="Unlock KillerNotes"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <TextBlock x:Name="DetailText"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" LineHeight="18" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <PasswordBox x:Name="PwBox" FontSize="13" Padding="6,4"
                                 Background="{DynamicResource BackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 CaretBrush="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                 BorderThickness="1" KeyDown="PwBox_KeyDown"/>
                    <TextBlock x:Name="ConfirmLabel" Text="confirm"
                               Foreground="{DynamicResource DimTextBrush}" FontSize="10"
                               Margin="0,8,0,2" Visibility="Collapsed"/>
                    <PasswordBox x:Name="PwConfirmBox" FontSize="13" Padding="6,4"
                                 Background="{DynamicResource BackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 CaretBrush="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                 BorderThickness="1" KeyDown="PwBox_KeyDown"
                                 Visibility="Collapsed"/>
                </StackPanel>

                <!-- Buttons. ExtraButton (left) is the unlock prompt's escape hatch: shown only
                     when the caller passes extraText (e.g. "New database..."). -->
                <Grid Grid.Row="2" Margin="24,0,24,20">
                    <Button x:Name="ExtraButton" Click="Extra_Click" Visibility="Collapsed"
                            Style="{StaticResource SurfaceButton}" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click"
                                Style="{StaticResource SurfaceButton}"
                                Width="80" Margin="0,0,8,0"/>
                        <!-- OutlineButton (family standard): accent outline, fills solid on hover -->
                        <Button x:Name="OkButton" Content="Unlock" Click="OK_Click"
                                Style="{StaticResource OutlineButton}"
                                Width="80"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

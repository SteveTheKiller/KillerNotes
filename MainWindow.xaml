<Window x:Class="KillerNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="KillerNotes"
        WindowStyle="None" Background="{DynamicResource BackgroundBrush}"
        MinWidth="720" MinHeight="480" Width="1080" Height="700"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="8" CornerRadius="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Format-bar button: chrome hover behavior, editor-toolbar sizing (bigger glyphs) -->
        <Style x:Key="FmtButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <!-- Thin divider between format-bar groups -->
        <Style x:Key="FmtSeparator" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="5,6"/>
            <Setter Property="Fill" Value="{DynamicResource CardBorderBrush}"/>
        </Style>
        <!-- LIST / KEYBOARD caption toggle in the shortcuts overlay header; the active
             one's Foreground is driven from code (KeyboardMap.cs ApplyShortcutView) -->
        <Style x:Key="KsTabBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="2">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>   <!-- title bar -->
            <RowDefinition Height="*"/>    <!-- sidebar + editor -->
            <RowDefinition Height="24"/>   <!-- footer (family standard) -->
        </Grid.RowDefinitions>

        <!-- ============ Title bar ============ -->
        <Grid Grid.Row="0" Background="{DynamicResource BackgroundBrush}">
            <Border IsHitTestVisible="False" Opacity="{DynamicResource GrainOpacity}">
                <Border.Background>
                    <ImageBrush x:Name="TitleGrainBrush" TileMode="Tile" ViewportUnits="Absolute"
                                Viewport="0,0,256,256" Stretch="None"/>
                </Border.Background>
            </Border>

            <!-- App icon + wordmark ("Killer" in text color, "Notes" bold in the accent,
                 soft dark shadow copy) - same layout as the KillerScan title bar -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0"
                        HorizontalAlignment="Left">
                <Image Source="pack://application:,,,/Resources/kn-icon.png" Width="25" Height="25"
                       VerticalAlignment="Center" Margin="0,0,7,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Grid VerticalAlignment="Center" Background="Transparent">
                    <StackPanel Orientation="Horizontal" Margin="1,2,0,0"
                                Opacity="{DynamicResource IconShadowOpacity}">
                        <StackPanel.Effect><BlurEffect Radius="3"/></StackPanel.Effect>
                        <TextBlock FontFamily="{DynamicResource WordmarkFont}" FontSize="17"><Run Text="Killer" Foreground="#D8000000"/><Run Text="Notes" FontSize="22" FontWeight="Bold" Foreground="#D8000000"/></TextBlock>
                    </StackPanel>
                    <TextBlock FontFamily="{DynamicResource WordmarkFont}" FontSize="17"><Run Text="Killer" Foreground="{DynamicResource TextBrush}"/><Run Text="Notes" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/></TextBlock>
                </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- E8E5 (OpenFile): E8B7 renders as a missing-glyph box on some
                     Segoe MDL2 / Fluent Icons versions -->
                <Button x:Name="DatabasesBtn" Click="ManageDatabases_Click" Style="{StaticResource ChromeButton}"
                        Content="&#xE8E5;" ToolTip="Manage databases"/>
                <Button x:Name="LockButton" Click="LockButton_Click" Style="{StaticResource ChromeButton}"
                        Content="&#xE72E;" ToolTip="Password protection"/>
                <Button x:Name="MinimizeBtn" Click="MinimizeBtn_Click" Style="{StaticResource ChromeButton}" Content="&#xE921;"/>
                <Button x:Name="MaximizeBtn" Click="MaximizeBtn_Click" Style="{StaticResource ChromeButton}" Content="&#xE922;"/>
                <Button x:Name="CloseBtn"    Click="CloseBtn_Click"    Style="{StaticResource ChromeCloseButton}" Content="&#xE8BB;"/>
            </StackPanel>

            <!-- Theme + accent flyout. The theme button lives in the sidebar bottom (family
                 direction: appearance pickers out of the title bar); Placement=Top opens the
                 flyout upward from there. Both theme buttons retarget this popup on click. -->
            <Popup x:Name="ThemePopup" PlacementTarget="{Binding ElementName=ThemeButton}" Placement="Top"
                   StaysOpen="False" AllowsTransparency="True" VerticalOffset="-5">
                <Border Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource MenuBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="14">
                    <Border.Effect><DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="4" Direction="270" Opacity="0.55"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="theme" Foreground="{DynamicResource DimTextBrush}" FontSize="10" Margin="0,0,0,4"/>
                        <StackPanel x:Name="ThemeSwatches" Orientation="Horizontal">
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Dark"     Background="#3a3a3a" Click="ThemeSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Light"    Background="#e8e8e8" Click="ThemeSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Black"    Background="#000000" Click="ThemeSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Blood"    Background="#4a1f20" Click="ThemeSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Greed"    Background="#0a5234" Click="ThemeSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Cyanotic" Background="#0a4a6e" Click="ThemeSwatch_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="AccentLabel" Text="accent" Foreground="{DynamicResource DimTextBrush}" FontSize="10" Margin="0,8,0,4"/>
                        <StackPanel x:Name="AccentSwatches" Orientation="Horizontal">
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Red"    Background="#DD504B" Click="AccentSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Orange" Background="#E8962C" Click="AccentSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Green"  Background="#1ea54c" Click="AccentSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Teal"   Background="#1FB8A8" Click="AccentSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Blue"   Background="#50AEE8" Click="AccentSwatch_Click"/>
                            <Button Style="{StaticResource ThemeSwatch}" Tag="Purple" Background="#B982E3" Click="AccentSwatch_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <!-- ============ Sidebar + editor ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="280" MinWidth="200" MaxWidth="480"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Chrome strip behind the whole row: same BackgroundBrush as the title bar and
                 footer, so the sidebar and both bars merge into one chrome surface, and the
                 side margins carry the grain like the other bars (family pattern) -->
            <Border Grid.ColumnSpan="3" Background="{DynamicResource BackgroundBrush}">
                <Border IsHitTestVisible="False" Opacity="{DynamicResource GrainOpacity}"
                        Background="{DynamicResource GrainTileBrush}"/>
            </Border>

            <!-- Sidebar = collapsible panel + permanent icon rail on the CONTENT-PANE lip
                 (KillerPDF pattern: the icons live on the sidebar's inner edge, right next
                 to the document, in both states - they never move on collapse). -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <!-- Icon rail on the inner lip: collapse chevron top; ? and theme pinned bottom -->
                <Grid Grid.Column="1">
                    <!-- 4px left margin on centered elements = a 2px shift toward the pane,
                         so the icons sit visually centered on the rail -->
                    <Button x:Name="SidebarToggleBtn" Style="{StaticResource RailButton}"
                            Content="&#xE76B;" FontSize="12"
                            VerticalAlignment="Top" HorizontalAlignment="Center" Margin="4,10,0,0"
                            Click="SidebarToggle_Click" ToolTip="Collapse sidebar (F9)"/>
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="4,0,0,6">
                        <Button Style="{StaticResource RailButton}" Content="?"
                                FontFamily="Consolas" FontSize="18" Margin="0,0,0,6"
                                Click="ShortcutHelp_Click" ToolTip="Keyboard shortcuts (F1)"/>
                        <Button x:Name="ThemeButton" Style="{StaticResource RailButton}" Content="&#xE790;"
                                Click="SidebarThemeBtn_Click" ToolTip="Theme"/>
                    </StackPanel>
                </Grid>

                <DockPanel x:Name="SidebarPanel" Grid.Column="0" Margin="8,8,0,8">
                    <StackPanel DockPanel.Dock="Top">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Search box (KillerScan pattern): magnifier + placeholder, compact -->
                            <Border Grid.Column="0" Height="26" VerticalAlignment="Center"
                                    Background="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
                                        <Style.Triggers>
                                            <!-- Hover first, focus second so a focused box keeps the accent border -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource InputHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource DimTextBrush}" Margin="8,0,5,0" VerticalAlignment="Center"/>
                                    <Grid Grid.Column="1">
                                        <TextBlock Text="Search notes  (F3)" Foreground="{DynamicResource DimTextBrush}"
                                                   FontSize="12" VerticalAlignment="Center" IsHitTestVisible="False" Margin="0,0,8,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource TextBrush}" CaretBrush="{DynamicResource TextBrush}"
                                                 SelectionBrush="{DynamicResource PrimaryBrush}" SelectionOpacity="0.35"
                                                 FontSize="12" Padding="0,0,8,0" VerticalContentAlignment="Center"
                                                 TextChanged="SearchBox_TextChanged"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                        <Grid Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="NewNoteBtn" Grid.Column="0" Style="{StaticResource OutlineButton}"
                                    Content="+ New note" Click="NewNote_Click" HorizontalAlignment="Left"
                                    ToolTip="New note (Ctrl+N)"/>
                            <!-- Dedicated sorts: creation time (default, oldest first) and
                                 alphabetical. The active one shows in the accent; clicking it
                                 again reverses its direction (Notes.cs). -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <!-- Padding 0: SurfaceButton's 12px side padding clips glyphs at
                                     fixed widths. The active button carries a direction arrow
                                     (up = ascending) that flips when clicked again (Notes.cs). -->
                                <Button x:Name="SortTimeBtn" Style="{StaticResource SurfaceButton}"
                                        Margin="8,0,0,0" Click="SortTimeBtn_Click" Width="40" Padding="0"
                                        ToolTip="By creation time - oldest first (click again to reverse)">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="SortTimeArrow" Text="&#x2191;" FontFamily="Segoe UI"
                                                   FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="SortAlphaBtn" Style="{StaticResource SurfaceButton}"
                                        Margin="6,0,0,0" Click="SortAlphaBtn_Click" Width="40" Padding="0"
                                        ToolTip="Alphabetical (click again to reverse)">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="AZ" FontFamily="Consolas" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="SortAlphaArrow" Text="" FontFamily="Segoe UI"
                                                   FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <ListBox x:Name="NotesList" Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             SelectionChanged="NotesList_SelectionChanged"
                             PreviewMouseRightButtonDown="NotesList_PreviewMouseRightButtonDown"
                             PreviewMouseLeftButtonDown="NotesList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="NotesList_PreviewMouseMove"
                             AllowDrop="True" DragOver="NotesList_DragOver" Drop="NotesList_Drop">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="SnapsToDevicePixels" Value="True"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bg" Background="Transparent" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource RowSelectedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <!-- On the ListBox, not the item style: WPF cannot wire Click handlers on
                             elements inside a Style Setter (connectionId cast failure at load).
                             Right-click selects the item under the cursor first (code-behind). -->
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Share note..." Click="ShareNote_Click"
                                          ToolTip="Save as a .knote file (optionally password protected) to send to a coworker"/>
                                <MenuItem Header="Export note as..." Click="ExportNoteAs_Click"
                                          ToolTip="Save a copy as an ordinary file - .txt, .rtf, or .html (F8)"/>
                                <MenuItem Header="Delete note" Click="DeleteNote_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}"
                                               FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Snippet}" Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                    <TextBlock Text="{Binding ModifiedDisplay}" Foreground="{DynamicResource DimTextBrush}"
                                               FontSize="10" Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Grid>

            <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="False"/>

            <!-- Editor pane - the lightest tier, lifted above the chrome with an outward drop
                 shadow, flush to the title bar and footer so the shadow overlays them rather
                 than adding gap (same treatment as the KillerPDF/KillerScan content pane) -->
            <!-- Shadow caster: an empty twin border carries the pane's drop shadow. With
                 software rendering, an Effect on an ancestor re-renders the whole subtree
                 through the effect on every keystroke - typing lag - so the content pane
                 below stays effect-free. -->
            <Border Grid.Column="2" Background="{DynamicResource PaneBrush}"
                    BorderBrush="{DynamicResource PaneBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="0,0,8,0" Panel.ZIndex="9">
                <Border.CacheMode>
                    <BitmapCache/>
                </Border.CacheMode>
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
            </Border>
            <Border Grid.Column="2" Background="{DynamicResource PaneBrush}"
                    BorderBrush="{DynamicResource PaneBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="0,0,8,0" Panel.ZIndex="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Film grain over the whole pane (behind content, clipped to the rounded corners) -->
                <Border Grid.RowSpan="2" IsHitTestVisible="False" Opacity="0.20" Panel.ZIndex="-1" CornerRadius="3">
                    <Border.Background>
                        <ImageBrush x:Name="GrainBrush" TileMode="Tile"
                                    ViewportUnits="Absolute" Viewport="0,0,256,256" Stretch="None"/>
                    </Border.Background>
                </Border>

                <!-- Note title + faint rule dividing it from the content -->
                <StackPanel x:Name="TitleArea" Grid.Row="0">
                <TextBox x:Name="TitleBox" Margin="12,10,12,4"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextBrush}" CaretBrush="{DynamicResource TextBrush}"
                         SelectionBrush="{DynamicResource PrimaryBrush}" SelectionOpacity="0.35"
                         FontSize="17" FontWeight="SemiBold"
                         TextChanged="TitleBox_TextChanged">
                    <!-- Explicit menu: the framework's built-in editing menu ignores the app's
                         implicit ContextMenu/MenuItem styles, so it renders unthemed -->
                    <TextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Cut" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X"/>
                            <MenuItem Header="Copy" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"/>
                            <MenuItem Header="Paste" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V"/>
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>
                <Border Height="1" Margin="12,2,12,0" Opacity="0.5"
                        Background="{DynamicResource CardBorderBrush}"/>
                </StackPanel>

                <!-- Floating format bar, ported from KillerPDF's annotation bars: pops out of
                     the top beside the title, slides horizontally by its grip (edge-anchored
                     or center-parked, position persisted), and minimizes to a grip-dots peek
                     strip - chevron, F6, or double-click the grip/peek (FormatBar.cs) -->
                <Border x:Name="FormatBar" Grid.RowSpan="2" Panel.ZIndex="30"
                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,8,0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,1,1"
                        CornerRadius="0,0,4,4" Padding="4,2"
                        Effect="{StaticResource ShadowBar}">
                    <!-- Cache the bar + its shadow as a bitmap: with software rendering the
                         shadow would otherwise re-render on every keystroke it overlaps -->
                    <Border.CacheMode>
                        <BitmapCache/>
                    </Border.CacheMode>
                <Grid>
                    <!-- Film grain across the bar, KillerPDF-style; stays put when minimized -->
                    <Border IsHitTestVisible="False" CornerRadius="0,0,3,3" Margin="-4,-2"
                            Opacity="{DynamicResource GrainOpacity}"
                            Background="{DynamicResource GrainTileBrush}"/>

                    <!-- Peek strip shown while minimized: drag to move, double-click to restore -->
                    <Border x:Name="FmtPeek" Background="Transparent" Cursor="Hand" Height="13"
                            Visibility="Collapsed"
                            ToolTip="Drag to move - double-click or F6 to restore">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" IsHitTestVisible="False">
                            <Ellipse Width="3" Height="3" Margin="2,0" Fill="{DynamicResource DimTextBrush}"/>
                            <Ellipse Width="3" Height="3" Margin="2,0" Fill="{DynamicResource DimTextBrush}"/>
                            <Ellipse Width="3" Height="3" Margin="2,0" Fill="{DynamicResource DimTextBrush}"/>
                            <Ellipse Width="3" Height="3" Margin="2,0" Fill="{DynamicResource DimTextBrush}"/>
                            <Ellipse Width="3" Height="3" Margin="2,0" Fill="{DynamicResource DimTextBrush}"/>
                            <Ellipse Width="3" Height="3" Margin="2,0" Fill="{DynamicResource DimTextBrush}"/>
                        </StackPanel>
                    </Border>

                <StackPanel x:Name="FmtButtons" Orientation="Horizontal">
                    <!-- Drag grip (double-click minimizes, like KillerPDF) -->
                    <!-- Vertical 3-dot column, exactly like KillerPDF's MakeBarGrip -->
                    <Border x:Name="FmtGrip" Background="Transparent" Cursor="SizeAll" Width="14"
                            Margin="0,0,2,0" ToolTip="Drag to move - double-click to minimize">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" IsHitTestVisible="False">
                            <Ellipse Width="3" Height="3" Margin="0,1.5" Fill="{DynamicResource DimTextBrush}"/>
                            <Ellipse Width="3" Height="3" Margin="0,1.5" Fill="{DynamicResource DimTextBrush}"/>
                            <Ellipse Width="3" Height="3" Margin="0,1.5" Fill="{DynamicResource DimTextBrush}"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource FmtButton}" Content="&#xE8DD;" ToolTip="Bold (Ctrl+B)"
                            Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=Editor}"/>
                    <Button Style="{StaticResource FmtButton}" Content="&#xE8DB;" ToolTip="Italic (Ctrl+I)"
                            Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=Editor}"/>
                    <Button Style="{StaticResource FmtButton}" Content="&#xE8DC;" ToolTip="Underline (Ctrl+U)"
                            Command="EditingCommands.ToggleUnderline" CommandTarget="{Binding ElementName=Editor}"/>
                    <Button Style="{StaticResource FmtButton}" ToolTip="Strikethrough (Ctrl+Shift+S)" Click="Strike_Click">
                        <TextBlock Text="S" TextDecorations="Strikethrough" FontFamily="Segoe UI"
                                   FontSize="14" FontWeight="SemiBold"/>
                    </Button>
                    <Button Style="{StaticResource FmtButton}" Content="&#xE943;" ToolTip="Monospace (code, Ctrl+Shift+M)"
                            Click="Mono_Click"/>
                    <Rectangle Style="{StaticResource FmtSeparator}"/>
                    <!-- Word-style "A over a color bar" - the bar follows the accent -->
                    <Button x:Name="TextColorBtn" Style="{StaticResource FmtButton}"
                            ToolTip="Text color and highlight" Click="TextColorBtn_Click">
                        <StackPanel>
                            <TextBlock Text="A" FontFamily="Segoe UI" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,0,0,1"/>
                            <Rectangle Width="14" Height="3" RadiusX="1" RadiusY="1"
                                       Fill="{DynamicResource PrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="ColorPopup" PlacementTarget="{Binding ElementName=TextColorBtn}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="4">
                        <Border Background="{DynamicResource MenuBackgroundBrush}"
                                BorderBrush="{DynamicResource MenuBorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="14">
                            <Border.Effect><DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.55"/></Border.Effect>
                            <StackPanel>
                                <TextBlock Text="text" Foreground="{DynamicResource DimTextBrush}" FontSize="10" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource ThemeSwatch}" Background="{DynamicResource PrimaryBrush}" Tag="accent" Click="FgSwatch_Click" ToolTip="Accent"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#DD504B" Tag="#DD504B" Click="FgSwatch_Click"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#E8962C" Tag="#E8962C" Click="FgSwatch_Click"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#1ea54c" Tag="#1ea54c" Click="FgSwatch_Click"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#50AEE8" Tag="#50AEE8" Click="FgSwatch_Click"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#9a9a9a" Tag="#9a9a9a" Click="FgSwatch_Click"/>
                                    <Button Content="auto" Style="{StaticResource SurfaceButton}" FontSize="10"
                                            Padding="6,1" Margin="6,0,0,0" Click="FgAuto_Click"
                                            ToolTip="Back to the theme text color"/>
                                </StackPanel>
                                <TextBlock Text="highlight" Foreground="{DynamicResource DimTextBrush}" FontSize="10" Margin="0,8,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#7a6a00" Tag="#7A6A00" Click="BgSwatch_Click"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#0a5e2a" Tag="#0A5E2A" Click="BgSwatch_Click"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#084d6e" Tag="#084D6E" Click="BgSwatch_Click"/>
                                    <Button Style="{StaticResource ThemeSwatch}" Background="#6e1414" Tag="#6E1414" Click="BgSwatch_Click"/>
                                    <Button Content="none" Style="{StaticResource SurfaceButton}" FontSize="10"
                                            Padding="6,1" Margin="6,0,0,0" Click="BgNone_Click"
                                            ToolTip="Remove highlight"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Rectangle Style="{StaticResource FmtSeparator}"/>
                    <Button Style="{StaticResource FmtButton}" Content="&#xE8FD;" ToolTip="Bulleted list (Ctrl+Shift+L)"
                            Command="EditingCommands.ToggleBullets" CommandTarget="{Binding ElementName=Editor}"/>
                    <Button Style="{StaticResource FmtButton}" Content="&#xEA37;" ToolTip="Numbered list (Ctrl+Shift+N)"
                            Command="EditingCommands.ToggleNumbering" CommandTarget="{Binding ElementName=Editor}"/>
                    <Rectangle Style="{StaticResource FmtSeparator}"/>
                    <Button Style="{StaticResource FmtButton}" Content="&#xE738;" ToolTip="Horizontal rule (Ctrl+Shift+R)"
                            Click="InsertRule_Click"/>
                    <!-- Press (or press-hold-drag) opens the size picker grid; release or click
                         on a cell inserts that rows x cols table (Editor.cs). -->
                    <Button x:Name="TableBtn" Style="{StaticResource FmtButton}" Content="&#xE8A9;"
                            ToolTip="Insert table (drag to pick the size)"
                            PreviewMouseLeftButtonDown="TableBtn_MouseDown"/>
                    <Popup x:Name="TableSizePopup" PlacementTarget="{Binding ElementName=TableBtn}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="4">
                        <Border Background="{DynamicResource MenuBackgroundBrush}"
                                BorderBrush="{DynamicResource MenuBorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="12">
                            <Border.Effect><DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.55"/></Border.Effect>
                            <StackPanel>
                                <UniformGrid x:Name="TableSizeCells" Columns="8"/>
                                <TextBlock x:Name="TableSizeLabel" Text="size" Foreground="{DynamicResource DimTextBrush}"
                                           FontSize="10" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <!-- Custom size for anything beyond the hover grid -->
                                <Border Height="1" Background="{DynamicResource MenuBorderBrush}" Margin="0,8,0,8"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBox x:Name="TblColsBox" Style="{StaticResource DarkTextBox}" Text="4"
                                             Width="34" FontSize="11" Padding="4,2" KeyDown="TblCustom_KeyDown"
                                             ToolTip="Columns"/>
                                    <TextBlock Text=" x " Foreground="{DynamicResource DimTextBrush}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBox x:Name="TblRowsBox" Style="{StaticResource DarkTextBox}" Text="3"
                                             Width="34" FontSize="11" Padding="4,2" KeyDown="TblCustom_KeyDown"
                                             ToolTip="Rows"/>
                                    <Button Content="Insert" Style="{StaticResource SurfaceButton}"
                                            FontSize="11" Padding="8,2" Margin="8,0,0,0"
                                            Click="TblCustomInsert_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <!-- Appears only when the note text looks like markdown or HTML (Preview.cs) -->
                    <Button x:Name="PreviewBtn" Style="{StaticResource FmtButton}" Content="&#xE890;"
                            ToolTip="Preview (F4)" Click="TogglePreview_Click" Visibility="Collapsed"/>
                    <Rectangle Style="{StaticResource FmtSeparator}"/>
                    <Button Style="{StaticResource FmtButton}" Content="&#xE70E;" FontSize="10"
                            ToolTip="Hide format bar (F6)" Click="FormatBarToggle_Click"/>
                </StackPanel>
                </Grid>
                </Border>

                <!-- The note body. Content is stored as a XamlPackage blob, so pasted
                     images and real FlowDocument tables round-trip through the database.
                     The right column is the optional markdown/HTML preview (Preview.cs),
                     collapsed until the user opens it. -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="PreviewCol" Width="0"/>
                    </Grid.ColumnDefinitions>
                    <RichTextBox x:Name="Editor" Grid.Column="0" Margin="8,0,8,8"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextBrush}" CaretBrush="{DynamicResource TextBrush}"
                                 SelectionBrush="{DynamicResource PrimaryBrush}" SelectionOpacity="0.35"
                                 FontSize="13" AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="Editor_TextChanged">
                        <RichTextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Cut" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X"/>
                                <MenuItem Header="Copy" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"/>
                                <MenuItem Header="Paste" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V"/>
                            </ContextMenu>
                        </RichTextBox.ContextMenu>
                    </RichTextBox>
                    <!-- The WebBrowser (IE ActiveX) child is created lazily on first preview
                         open and disposed on close (Preview.cs) - a hosted IE control adds
                         message-loop overhead to the whole window just by existing. -->
                    <Border x:Name="PreviewPane" Grid.Column="1" Visibility="Collapsed"
                            BorderBrush="{DynamicResource PaneBorderBrush}" BorderThickness="1,0,0,0"
                            Margin="0,0,8,8"/>
                </Grid>

                <!-- Shown when no note is selected. Clicking starts a new note; dropped
                     text or images start a new note carrying them (Notes.cs / Editor.cs). -->
                <Grid x:Name="EmptyState" Grid.Row="0" Grid.RowSpan="2" Background="Transparent"
                      Cursor="IBeam" AllowDrop="True"
                      MouseLeftButtonDown="EmptyState_MouseDown"
                      DragOver="EmptyState_DragOver" Drop="EmptyState_Drop">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"
                               Foreground="{DynamicResource DimTextBrush}" FontSize="13"
                               Text="Click to start a new note, drop text or an image here, or pick one on the left."/>
                </Grid>
            </Grid>
            </Border>
        </Grid>

        <!-- Status bar (exact copy of KillerScan's: 24px, Consolas 11.5/10, family standard) -->
        <Border Grid.Row="2" Background="{DynamicResource BackgroundBrush}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Film grain over the bar (negative margin pulls it to the full width) -->
                <Border Grid.ColumnSpan="3" IsHitTestVisible="False" Opacity="{DynamicResource GrainOpacity}" Margin="-16,0">
                    <Border.Background>
                        <ImageBrush x:Name="StatusGrainBrush" TileMode="Tile"
                                    ViewportUnits="Absolute" Viewport="0,0,256,256" Stretch="None"/>
                    </Border.Background>
                </Border>
                <TextBlock x:Name="StatusText" Grid.Column="0" Text="Ready"
                           Foreground="{DynamicResource ChromeTextBrush}" FontFamily="Consolas"
                           FontSize="11.5" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="VersionLabel" Text="v0.1.0"
                               Foreground="{DynamicResource TextFooter}" FontFamily="Consolas"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"
                               Cursor="Hand" ToolTip="About KillerNotes"
                               MouseLeftButtonUp="VersionLabel_Click"/>
                    <!-- 14px trailing margin keeps the copyright clear of the corner grip (family standard) -->
                    <TextBlock FontSize="10" VerticalAlignment="Center"
                               FontFamily="Consolas" Margin="0,0,14,0">
                        <Run Text="&#x00A9; 2026 " Foreground="{DynamicResource TextFooter}"/>
                        <Hyperlink NavigateUri="https://thekiller.net"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{DynamicResource TextFooter}" TextDecorations="None">
                            <Run Text="Steve the Killer"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Custom bottom-right resize grip (6 dots), ported from KillerPDF. Sits at the visible
             content corner and forwards a HTBOTTOMRIGHT resize to Windows on drag. -->
        <Canvas x:Name="ResizeGripDots" Grid.Row="2" Width="13" Height="13" Panel.ZIndex="50"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,4"
                Background="Transparent" Cursor="SizeNWSE"
                MouseLeftButtonDown="ResizeGrip_MouseDown">
            <Rectangle Canvas.Left="10" Canvas.Top="2"  Width="2" Height="2" Fill="{DynamicResource DimTextBrush}"/>
            <Rectangle Canvas.Left="6"  Canvas.Top="6"  Width="2" Height="2" Fill="{DynamicResource DimTextBrush}"/>
            <Rectangle Canvas.Left="10" Canvas.Top="6"  Width="2" Height="2" Fill="{DynamicResource DimTextBrush}"/>
            <Rectangle Canvas.Left="2"  Canvas.Top="10" Width="2" Height="2" Fill="{DynamicResource DimTextBrush}"/>
            <Rectangle Canvas.Left="6"  Canvas.Top="10" Width="2" Height="2" Fill="{DynamicResource DimTextBrush}"/>
            <Rectangle Canvas.Left="10" Canvas.Top="10" Width="2" Height="2" Fill="{DynamicResource DimTextBrush}"/>
        </Canvas>

        <!-- About overlay: dims the window behind it and shows a centred card (structure copied
             from KillerScan; the close X is blended into the card with a red hover). -->
        <Grid x:Name="AboutOverlay" Grid.RowSpan="3" Panel.ZIndex="9000" Visibility="Collapsed"
              Background="#88000000" MouseLeftButtonDown="AboutOverlay_Click">
            <Grid Width="454" VerticalAlignment="Center" MouseLeftButtonDown="AboutCard_Click">
                <!-- Shadow on a separate element so the card text stays crisp -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" IsHitTestVisible="False">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="26" ShadowDepth="5" Direction="270" Opacity="0.6"/>
                    </Border.Effect>
                </Border>
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <!-- Film grain over the whole card (behind content) -->
                        <Border IsHitTestVisible="False" CornerRadius="6"
                                Opacity="{DynamicResource GrainOpacity}" Background="{DynamicResource GrainTileBrush}"/>

                        <!-- Close X: just the glyph turns red on hover (no filled square), like KillerPDF. -->
                        <Button Content="&#x2715;" Click="AboutClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Width="28" Height="26" Margin="0,6,6,0" Panel.ZIndex="2" FontSize="11"
                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#E04444"/>
                                                        <Setter TargetName="cp" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.5"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <StackPanel Margin="18,10,18,18">
                            <!-- Header: icon left of the wordmark + description (KillerScan layout) -->
                            <Grid Margin="0,4,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="pack://application:,,,/Resources/kn-icon.png" Width="58" Height="58"
                                       Margin="0,0,15,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="3" Direction="270" Opacity="0.55"/>
                                    </Image.Effect>
                                </Image>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Grid Margin="0,0,0,4" HorizontalAlignment="Left">
                                        <TextBlock FontFamily="{DynamicResource WordmarkFont}" Margin="1,2,0,0" IsHitTestVisible="False"
                                                   Opacity="{DynamicResource IconShadowOpacity}"><TextBlock.Effect><BlurEffect Radius="2"/></TextBlock.Effect><Run Text="Killer" FontSize="22" Foreground="#C0000000"/><Run Text="Notes" FontSize="28.6" FontWeight="Bold" Foreground="#C0000000"/></TextBlock>
                                        <TextBlock FontFamily="{DynamicResource WordmarkFont}"><Run Text="Killer" FontSize="22" Foreground="{DynamicResource TextBrush}"/><Run Text="Notes" FontSize="28.6" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/></TextBlock>
                                    </Grid>
                                    <TextBlock FontSize="12" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"><Run Text="Notes that keep up. A GPLv3 "/><Hyperlink NavigateUri="https://killertools.net" RequestNavigate="AboutLink_Navigate" Foreground="{DynamicResource PrimaryBrush}" TextDecorations="None">Killer Tools</Hyperlink><Run Text=" utility."/></TextBlock>
                                </StackPanel>
                            </Grid>

                            <!-- Info panel - matte, lifted above the grainy card -->
                            <Grid>
                                <Border Background="{DynamicResource PaneBrush}" CornerRadius="4" IsHitTestVisible="False">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="2" Direction="270" Opacity="0.5"/>
                                    </Border.Effect>
                                </Border>
                                <Border Background="{DynamicResource PaneBrush}" CornerRadius="4" Padding="14,12,14,4">
                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Version" Foreground="{DynamicResource DimTextBrush}" FontFamily="Consolas" FontSize="10"/>
                                            <TextBlock x:Name="AboutVersionBlock" Foreground="{DynamicResource PrimaryBrush}"
                                                       FontFamily="Consolas" FontSize="13" Cursor="Hand"
                                                       MouseLeftButtonUp="AboutVersion_Click" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Publisher" Foreground="{DynamicResource DimTextBrush}" FontFamily="Consolas" FontSize="10"/>
                                            <TextBlock x:Name="AboutPublisherBlock" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="Certificate thumbprint" Foreground="{DynamicResource DimTextBrush}" FontFamily="Consolas" FontSize="10"/>
                                            <TextBlock x:Name="AboutThumbprintBlock" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="EXE SHA-256" Foreground="{DynamicResource DimTextBrush}" FontFamily="Consolas" FontSize="10"/>
                                            <TextBlock x:Name="AboutSha256Block" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Update notice: shown only when a newer release is found -->
                            <Button x:Name="AboutUpdateButton" Visibility="Collapsed" Margin="0,14,0,0"
                                    HorizontalAlignment="Left" Cursor="Hand" Click="AboutUpdateButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ub" Background="Transparent" BorderBrush="{DynamicResource PrimaryBrush}"
                                                BorderThickness="1" CornerRadius="4" Padding="14,7">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ub" Property="Background" Value="{DynamicResource RowSelectedBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock x:Name="AboutUpdateText" Text="Update available" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Shortcuts overlay (F1): same card language as About; mutually exclusive with it -->
        <Grid x:Name="ShortcutOverlay" Grid.RowSpan="3" Panel.ZIndex="9100" Visibility="Collapsed"
              Background="#88000000" MouseLeftButtonDown="ShortcutOverlay_Click">
            <Grid x:Name="ShortcutCardGrid" MinWidth="380" MaxWidth="380"
                  VerticalAlignment="Center" MouseLeftButtonDown="ShortcutCard_Click">
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" IsHitTestVisible="False">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="26" ShadowDepth="5" Direction="270" Opacity="0.6"/>
                    </Border.Effect>
                </Border>
                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Border IsHitTestVisible="False" CornerRadius="6"
                                Opacity="{DynamicResource GrainOpacity}" Background="{DynamicResource GrainTileBrush}"/>
                        <StackPanel Margin="18,14,18,18">
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Keyboard shortcuts" Foreground="{DynamicResource TextBrush}"
                                           FontFamily="Consolas" FontSize="15" FontWeight="Bold"/>
                                <!-- LIST / KEYBOARD view toggle (KeyboardMap.cs) -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                            VerticalAlignment="Center" Margin="0,0,36,0">
                                    <Button x:Name="KsViewListBtn" Style="{StaticResource KsTabBtn}"
                                            Content="LIST" Click="KsViewList_Click" Margin="0,0,12,0"/>
                                    <Button x:Name="KsViewKeyboardBtn" Style="{StaticResource KsTabBtn}"
                                            Content="KEYBOARD" Click="KsViewKeyboard_Click"/>
                                </StackPanel>
                                <!-- Foreground lives in a Style setter, NOT a local attribute:
                                     a local value outranks the template's hover trigger and
                                     the X never turned red -->
                                <Button Content="&#x2715;" Click="ShortcutClose_Click" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Width="28" Height="22" FontSize="11" Panel.ZIndex="2"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent">
                                                            <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="#E04444"/>
                                                                <Setter TargetName="cp" Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.5"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                            <!-- Rows are built in code (Shortcuts.cs BuildShortcutRows) so the
                                 list stays next to the handlers that implement it -->
                            <Grid x:Name="ShortcutListHost">
                                <StackPanel x:Name="ShortcutRows"/>
                            </Grid>
                            <!-- KEYBOARD view - generated by KeyboardMap.cs, hidden until toggled -->
                            <StackPanel x:Name="ShortcutKeyboardHost" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
